<launch>
  <param name="use_sim_time" value="true" />

  <!-- SUP-01 Phase E: launch for JokerJohn/LIO_SAM_6AXIS fork. Package
       name changed from `lio_sam` (upstream) to `lio_sam_6axis`;
       executables gain the `_6axis_` infix. No gpsOdometry node —
       useGPS=false in params. Backup of upstream launch in
       kitti.launch.bak_upstream. -->

  <!-- Load LIO-SAM-6AXIS parameters for KITTI HDL-64E -->
  <rosparam command="load" file="/config/params.yaml" />

  <!-- 6AXIS-specific: configDirectory + saveDirectory are read by the fork
       for kml export and save_map service. Point them at in-container
       paths; our flow records odometry via rosbag, not via /save_map. -->
  <param name="configDirectory" type="string" value="/config/" />
  <param name="saveDirectory" type="string" value="/tmp/lio_sam_6axis/" />
  <rosparam param="sequence">kitti</rosparam>

  <!-- LIO-SAM-6AXIS nodes (package name lio_sam_6axis, executables gain
       the _6axis_ infix) -->
  <node pkg="lio_sam_6axis" type="lio_sam_6axis_imuPreintegration"
        name="lio_sam_6axis_imuPreintegration" output="screen" respawn="false" />
  <node pkg="lio_sam_6axis" type="lio_sam_6axis_imageProjection"
        name="lio_sam_6axis_imageProjection" output="screen" respawn="false" />
  <node pkg="lio_sam_6axis" type="lio_sam_6axis_featureExtraction"
        name="lio_sam_6axis_featureExtraction" output="screen" respawn="false" />
  <node pkg="lio_sam_6axis" type="lio_sam_6axis_mapOptmization"
        name="lio_sam_6axis_mapOptmization" output="screen" respawn="false" />
</launch>
