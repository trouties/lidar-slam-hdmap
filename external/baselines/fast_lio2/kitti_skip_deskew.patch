# SUP-01 Phase C — FAST-LIO2 skip-deskew patch for KITTI data.
#
# Target upstream: hku-mars/FAST_LIO
#   commit 7cc4175de6f8ba2edf34bab02a42195b141027e9 (2024-07-23 "Support MARSIM simulator.")
#
# Purpose
#   KITTI Odometry .bin point clouds are already motion-compensated by the
#   HDL-64E vendor (deskewed to scan-center pose). FAST-LIO2's default
#   UndistortPcl runs backward-propagation point-level compensation a second
#   time, causing 134 m APE_SE3 on Seq 00 (Phase B.2 v3, see
#   refs/sup-notes.md SUP-01 Phase B and results/diagnostics/phaseB_report.md).
#
# Behavior
#   Adds a ROS parameter `preprocess/skip_undistortion` (default false, so
#   the upstream behavior is preserved when the flag is absent). When true,
#   the per-point backward-propagation compensation loop inside
#   ImuProcess::UndistortPcl is short-circuited; IMU forward propagation and
#   kf_state.predict calls remain intact so ESKF state evolution is unaffected.
#
# Apply
#   Inside `/catkin_ws/src/FAST_LIO` in the Docker image:
#     git apply /tmp/kitti_skip_deskew.patch
#   See external/baselines/fast_lio2/Dockerfile.
#
# Revert
#   git apply -R /tmp/kitti_skip_deskew.patch
#
# Scope
#   3 hunks, 10 insertions, 1 deletion. All guarded behind the new flag; the
#   default-false path is a byte-for-byte no-op relative to upstream.
#
diff --git a/src/IMU_Processing.hpp b/src/IMU_Processing.hpp
index 344d07f..9db2bd1 100644
--- a/src/IMU_Processing.hpp
+++ b/src/IMU_Processing.hpp
@@ -61,6 +61,13 @@ class ImuProcess
   V3D cov_bias_acc;
   double first_lidar_time;
   int lidar_type;
+  // SUP-01 Phase C: when true, bypass point-level backward motion compensation
+  // in UndistortPcl (KITTI .bin is already vendor-deskewed; running deskew on
+  // already-deskewed points causes double-compensation, ~134 m APE_SE3 on
+  // Seq 00 per Phase B.2 v3 diagnosis). IMU forward propagation and kf_state
+  // prediction remain enabled; only the per-point compensation loop is
+  // short-circuited. Default false preserves upstream behavior.
+  bool   skip_undistortion = false;

  private:
   void IMU_init(const MeasureGroup &meas, esekfom::esekf<state_ikfom, 12, input_ikfom> &kf_state, int &N);
@@ -307,7 +314,9 @@ void ImuProcess::UndistortPcl(const MeasureGroup &meas, esekfom::esekf<state_ikf
   /*** undistort each lidar point (backward propagation) ***/
   if (pcl_out.points.begin() == pcl_out.points.end()) return;

-  if(lidar_type != MARSIM){
+  // SUP-01 Phase C: skip_undistortion bypasses this loop for KITTI-like data
+  // whose points are already motion-compensated to the scan-center pose.
+  if(lidar_type != MARSIM && !skip_undistortion){
       auto it_pcl = pcl_out.points.end() - 1;
       for (auto it_kp = IMUpose.end() - 1; it_kp != IMUpose.begin(); it_kp--)
       {
diff --git a/src/laserMapping.cpp b/src/laserMapping.cpp
index fc41408..3426e2b 100644
--- a/src/laserMapping.cpp
+++ b/src/laserMapping.cpp
@@ -785,6 +785,8 @@ int main(int argc, char** argv)
     nh.param<int>("preprocess/scan_rate", p_pre->SCAN_RATE, 10);
     nh.param<int>("point_filter_num", p_pre->point_filter_num, 2);
     nh.param<bool>("feature_extract_enable", p_pre->feature_enabled, false);
+    // SUP-01 Phase C: skip point-level deskew for KITTI (pre-compensated .bin).
+    nh.param<bool>("preprocess/skip_undistortion", p_imu->skip_undistortion, false);
     nh.param<bool>("runtime_pos_log_enable", runtime_pos_log, 0);
     nh.param<bool>("mapping/extrinsic_est_en", extrinsic_est_en, true);
     nh.param<bool>("pcd_save/pcd_save_en", pcd_save_en, false);
