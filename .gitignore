# SUP-06 uncertainty viz — only ship the minimum artifacts needed
# for README rendering (2 animated GIFs + JSON report + loose CSV).
# PNGs / tight CSV / trajectory .npy stay local for re-render only.
benchmarks/uncertainty/*
!benchmarks/uncertainty/ellipsoid_animation_00_loose.gif
!benchmarks/uncertainty/ellipsoid_animation_00_tight.gif
!benchmarks/uncertainty/sup06_report_00.json
!benchmarks/uncertainty/marginal_cov_00_loose.csv

# SUP-08 — colcon build generates transient build/install/log trees we do
# not want to track. Package source (ros2_ws/src/) stays in git.
ros2_ws/build/
ros2_ws/install/
ros2_ws/log/

# SUP-09 — compose acceptance run logs are transient. Keep only the canonical
# artifacts (summary JSON + sha256 + the committed trajectory screenshot).
benchmarks/sup09/build.log
benchmarks/sup09/up.log
benchmarks/sup09/http_server.log
